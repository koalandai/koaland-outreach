# Koaland Prospect Intelligence OS — local server configuration
# Copy to .env and fill in. Every key is optional locally; features degrade
# gracefully (mock audits/emails, logged-only sends, mock discovery).

# Dashboard login token (default: local-dev)
DASHBOARD_ACCESS_TOKEN=local-dev

# Real AI audits, email generation, and campaign planning (GPT-4o)
OPENAI_API_KEY=

# Real email sending. Without it, sends are logged-only — nothing leaves.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=murat@koaland.ai
SENDGRID_FROM_NAME=Murat

# Real prospect discovery via Google SERP (otherwise mock hotels are generated)
SERP_API_KEY=
SERP_PROVIDER=serpapi   # serpapi | valueserp | serper

# Optional
PAGESPEED_API_KEY=
TRACKING_BASE_URL=http://localhost:3000
PORT=3000
