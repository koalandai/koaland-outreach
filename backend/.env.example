# ─── DASHBOARD ACCESS ───────────────────────────────────────────
DASHBOARD_ACCESS_TOKEN=your_secret_token_here

# ─── OPENAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── SENDGRID ───────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=murat@koaland.ai
SENDGRID_FROM_NAME=Murat
SENDGRID_WEBHOOK_PUBLIC_KEY=

# ─── PAGESPEED ──────────────────────────────────────────────────
PAGESPEED_API_KEY=AIza...

# ─── SERP ───────────────────────────────────────────────────────
SERP_API_KEY=
SERP_PROVIDER=serpapi
# Options: serpapi | valueserp | serper

# ─── TRACKING ───────────────────────────────────────────────────
TRACKING_BASE_URL=https://your-app.vercel.app

# ─── VERCEL KV (Storage) ────────────────────────────────────────
# Add Vercel KV from the Vercel dashboard — env vars auto-added:
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ─── VERCEL BLOB (PDF Storage) ──────────────────────────────────
# Add Vercel Blob from the Vercel dashboard — env var auto-added:
BLOB_READ_WRITE_TOKEN=

# ─── CORS ───────────────────────────────────────────────────────
APP_ALLOWED_ORIGIN=*
