{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": ".vercel/output",
    "rootDir": ".",
    "moduleResolution": "node"
  },
  "include": ["api/**/*", "services/**/*", "middleware/**/*", "utils/**/*", "prompts/**/*"],
  "exclude": ["node_modules", "frontend"]
}
